{
  "manifest_version": 3,
  "key": "",
  "name": "MasterBot Bridge",
  "version": "0.3.0",
  "description": "Bridge for MasterBot site to query Jobber and MAPRO on the user's behalf using their existing browser session.",
  "icons": {
    "48": "MasterLogo.jpg",
    "128": "MasterLogo.jpg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://secure.getjobber.com/*",
    "https://app.mapro.us/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.mapro.us/booking/reservation/*"],
      "js": ["mapro-content.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://alissonrochah.github.io/*",
      "http://localhost:*/*"
    ]
  }
}
