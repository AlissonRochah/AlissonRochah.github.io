{
  "manifest_version": 3,
  "key": "",
  "name": "MasterBot Bridge",
  "version": "0.8.20",
  "description": "Bridge for MasterBot site to query Jobber, MAPRO, and submit guests to Champions Gate access on the user's behalf using their existing browser session.",
  "icons": {
    "48": "MasterLogo.jpg",
    "128": "MasterLogo.jpg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "cookies",
    "declarativeNetRequestWithHostAccess"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "gate_rules",
        "enabled": true,
        "path": "gate-rules.json"
      }
    ]
  },
  "host_permissions": [
    "https://secure.getjobber.com/*",
    "https://app.mapro.us/*",
    "https://gateaccess.net/*",
    "https://docs.google.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.mapro.us/booking/reservation/*"],
      "js": ["mapro-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gateaccess.net/*"],
      "js": ["gate-visibility-override.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://alissonrochah.github.io/*",
      "http://localhost:*/*"
    ]
  }
}
